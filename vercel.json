{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.trilhaempreendedora.com.br" }],
      "destination": "https://trilhaempreendedora.com.br/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|robots.txt|sitemap.xml|og-image.svg|favicon.ico|google[a-f0-9]+\\.html).*)", "destination": "/index.html" }
  ]
}
